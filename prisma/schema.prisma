generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum ProductCategory {
  FRUIT
  VEGETABLE
  LEGUME
}

enum ProductImageKind {
  HERO
  WHOLE
  CUT
  IDEAL_STATE
  UNRIPE_STATE
  DEFECT
  STORAGE
  USAGE
  OTHER
}

enum ProductGuideSectionKind {
  CHOOSE
  OBSERVE
  STORE
  USE
  QUICK_FACTS
  OTHER
}

enum ArticleCategory {
  TIPS
  STORAGE
  SEASONALITY
  RECIPES
  WASTE_REDUCTION
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

model User {
  id                              String          @id @default(uuid())
  name                            String
  email                           String          @unique
  passwordHash                    String
  avatarUrl                       String?
  gender                          Gender?
  role                            UserRole        @default(USER)
  emailVerified                   Boolean         @default(false)
  emailVerifiedAt                 DateTime?
  emailConfirmationCodeHash       String?
  emailConfirmationCodeExpiresAt  DateTime?
  emailConfirmationCodeSentAt     DateTime?
  emailConfirmationAttempts       Int             @default(0)
  passwordResetCodeHash           String?
  passwordResetCodeExpiresAt      DateTime?
  passwordResetCodeSentAt         DateTime?
  passwordResetAttempts           Int             @default(0)
  createdAt                       DateTime        @default(now())
  updatedAt                       DateTime        @updatedAt
  articles                        Article[]
  productFavorites                ProductFavorite[]
  savedArticles                   SavedArticle[]
  preferences                     UserPreference?
}

model Product {
  id               String           @id @default(uuid())
  name             String
  slug             String           @unique
  category         ProductCategory
  shortDescription String
  description      String?
  imageUrl         String?
  benefits         String[]
  howToChoose      String[]
  howToStore       String[]
  usageTips        String[]
  nutrients        Json?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  images           ProductImage[]
  guideSections    ProductGuideSection[]
  favorites        ProductFavorite[]
  articleRelations ProductArticle[]
}

model ProductFavorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId, createdAt])
  @@index([productId])
}

model ProductImage {
  id         String           @id @default(cuid())
  productId  String
  product    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  url        String
  alt        String?
  caption    String?
  kind       ProductImageKind
  sortOrder  Int              @default(0)
  isPrimary  Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([productId, sortOrder])
}

model ProductGuideSection {
  id           String                  @id @default(cuid())
  productId    String
  product      Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  kind         ProductGuideSectionKind
  title        String
  body         String
  imageUrl     String?
  imageAlt     String?
  imageCaption String?
  bullets      String[]
  idealPoints  String[]
  avoidPoints  String[]
  sortOrder    Int                     @default(0)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([productId, sortOrder])
}

model Article {
  id               String           @id @default(uuid())
  title            String
  slug             String           @unique
  summary          String
  content          String
  category         ArticleCategory
  imageUrl         String?
  tags             String[]
  authorId         String
  author           User             @relation(fields: [authorId], references: [id], onDelete: Restrict)
  publishedAt      DateTime?
  isPublished      Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  productRelations ProductArticle[]
  savedBy          SavedArticle[]
}

model SavedArticle {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@index([userId, createdAt])
  @@index([articleId])
}

model ProductArticle {
  id        String   @id @default(cuid())
  productId String
  articleId String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([productId, articleId])
  @@index([productId, sortOrder, createdAt])
  @@index([articleId, sortOrder, createdAt])
}

model UserPreference {
  id                    String   @id @default(uuid())
  userId                String   @unique
  notificationsEnabled  Boolean  @default(true)
  seasonalTipsEnabled   Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
